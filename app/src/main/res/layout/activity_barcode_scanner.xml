<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:paddingTop="40dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#FFFFFF"
        android:elevation="10dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:contentDescription="@string/back"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:paddingTop="20dp"
            android:text="@string/barcode_scanner"
            android:textColor="#212121"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <!-- Camera Preview fills remaining space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Live camera feed -->
        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Scanner overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/align_barcode"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <!-- Scanner frame -->
            <FrameLayout
                android:layout_width="260dp"
                android:layout_height="180dp"
                android:background="@drawable/scanner_frame_bg">

                <View
                    android:id="@+id/scannerLine"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#31835D"
                    android:layout_gravity="top"
                    android:alpha="0.9" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/scanner_corners"
                    android:contentDescription="@string/scanner_frame" />
            </FrameLayout>

            <TextView
                android:id="@+id/scanningStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scanning_status"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnManualEntry"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:text="@string/manual_entry"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#31835D"
                    android:layout_marginEnd="12dp"
                    android:stateListAnimator="@null"
                    style="@style/Widget.MaterialComponents.Button" />

                <Button
                    android:id="@+id/btnHelp"
                    android:layout_width="100dp"
                    android:layout_height="48dp"
                    android:text="@string/help"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#52D17C"
                    android:stateListAnimator="@null"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="12dp"
        android:weightSum="4"
        android:baselineAligned="false">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            app:drawableTopCompat="@drawable/ic_home"
            android:drawablePadding="4dp"
            android:text="Home"
            android:textSize="12sp"
            android:textColor="#757575"
            android:minHeight="48dp"
            android:clickable="true"
            android:focusable="true"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/navCategories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            app:drawableTopCompat="@drawable/ic_categories"
            android:drawablePadding="4dp"
            android:text="Categories"
            android:textSize="12sp"
            android:textColor="#757575"
            android:minHeight="48dp"
            android:clickable="true"
            android:focusable="true"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/navCart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            app:drawableTopCompat="@drawable/ic_cart"
            android:drawablePadding="4dp"
            android:text="Cart"
            android:textSize="12sp"
            android:textColor="#757575"
            android:minHeight="48dp"
            android:clickable="true"
            android:focusable="true"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            app:drawableTopCompat="@drawable/ic_profile"
            android:drawablePadding="4dp"
            android:text="Profile"
            android:textSize="12sp"
            android:textColor="#757575"
            android:minHeight="48dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>