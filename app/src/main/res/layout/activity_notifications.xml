<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:paddingTop="40dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#FFFFFF"
        android:elevation="10dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:contentDescription="@string/back"
            android:focusable="true"
            android:padding="12dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:paddingTop="20dp"
            android:text="@string/notifications"
            android:textColor="#212121"
            android:textSize="20sp"
            android:textStyle="bold"/>

    </RelativeLayout>

    <!-- Bottom Navigation (Settings style) -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="4"
        android:baselineAligned="false"
        android:elevation="8dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            app:drawableTopCompat="@drawable/ic_home"
            android:drawablePadding="4dp"
            android:text="Home"
            android:textSize="12sp"
            android:textColor="#757575"
            android:minHeight="48dp"
            android:clickable="true"
            android:focusable="true"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/navCategories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            app:drawableTopCompat="@drawable/ic_categories"
            android:drawablePadding="4dp"
            android:text="Categories"
            android:textSize="12sp"
            android:textColor="#757575"
            android:minHeight="48dp"
            android:clickable="true"
            android:focusable="true"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/navCart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            app:drawableTopCompat="@drawable/ic_cart"
            android:drawablePadding="4dp"
            android:text="Cart"
            android:textSize="12sp"
            android:textColor="#757575"
            android:minHeight="48dp"
            android:clickable="true"
            android:focusable="true"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            app:drawableTopCompat="@drawable/ic_profile"
            android:drawablePadding="4dp"
            android:text="Profile"
            android:textSize="12sp"
            android:textColor="#757575"
            android:minHeight="48dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Notifications List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerNotifications"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomNavigation"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <!-- Empty State -->
    <TextView
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:visibility="gone"
        android:text="@string/no_notifications"
        android:textColor="#616161"
        android:textSize="16sp"
        android:drawableTop="@drawable/ic_notifications"
        android:drawablePadding="16dp"
        app:drawableTint="#CCCCCC"/>

</RelativeLayout>